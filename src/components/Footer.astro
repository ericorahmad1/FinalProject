---
import { socials } from '../data/projects';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-4 py-12 sm:px-6 md:flex-row md:justify-between">
    <div class="text-center md:text-left">
      <a href="#home" class="text-lg font-bold tracking-tight text-slate-900 dark:text-white">
        Erico<span class="text-brand-600 dark:text-brand-400">Rahmad</span>
      </a>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
        Final Project Hacktiv8 X DevC
      </p>
    </div>

    <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2">
      {socials.map((s) => (
        <li>
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-slate-500 underline-offset-4 transition-colors hover:text-brand-600 hover:underline dark:text-slate-400 dark:hover:text-brand-400"
          >
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="border-t border-slate-200 py-6 text-center text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400">
    &copy; {year} Erico Rahmad. Dibuat dengan Astro &amp; Tailwind CSS.
  </div>
</footer>
