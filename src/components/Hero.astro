---
import { socials } from '../data/projects';
---

<section
  id="home"
  class="relative flex min-h-screen items-center overflow-hidden bg-gradient-to-br from-brand-50 via-white to-sky-50 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950"
>
  <!-- Decorative blobs -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute -left-24 top-24 h-72 w-72 rounded-full bg-brand-400/20 blur-3xl dark:bg-brand-600/20"></div>
    <div class="absolute -right-24 bottom-24 h-72 w-72 rounded-full bg-sky-400/20 blur-3xl dark:bg-sky-600/20"></div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-32 sm:px-6">
    <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-brand-600 dark:text-brand-400">
      Final Project Hacktiv8 X DevC
    </p>
    <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl md:text-6xl dark:text-white">
      Halo, saya <span class="text-brand-600 dark:text-brand-400">Erico Rahmad</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 dark:text-slate-300">
      Seorang web developer yang membangun antarmuka modern, responsif, dan cepat.
      Selamat datang di halaman portfolio saya.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#portfolio"
        class="rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-600/20 transition-colors hover:bg-brand-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600"
      >
        Lihat Karya
      </a>
      <a
        href="#contact"
        class="rounded-xl border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition-colors hover:border-brand-600 hover:text-brand-600 dark:border-slate-700 dark:text-slate-200 dark:hover:border-brand-400 dark:hover:text-brand-400"
      >
        Hubungi Saya
      </a>
    </div>

    <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      {socials.map((s) => (
        <li>
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-slate-500 underline-offset-4 transition-colors hover:text-brand-600 hover:underline dark:text-slate-400 dark:hover:text-brand-400"
          >
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
