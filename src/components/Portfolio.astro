---
import { projects } from '../data/projects';

const iconLink =
  'inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 transition-colors hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300';
---

<section id="portfolio" class="scroll-mt-20 bg-slate-50 py-24 dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      Portfolio
    </h2>
    <div class="mt-4 h-1 w-16 rounded-full bg-brand-600"></div>
    <p class="mt-4 max-w-2xl text-slate-600 dark:text-slate-300">
      Beberapa proyek pilihan. Ganti dengan karya nyata Anda di
      <code class="rounded bg-slate-200 px-1.5 py-0.5 text-sm dark:bg-slate-800">src/data/projects.ts</code>.
    </p>

    <ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <li class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200 transition-shadow hover:shadow-lg dark:bg-slate-950 dark:ring-slate-800">
          <div class={`h-44 bg-gradient-to-br ${project.gradient}`} aria-hidden="true"></div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white">{project.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
              {project.description}
            </p>
            <ul class="mt-4 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <li class="rounded-md bg-slate-100 px-2 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                  {tag}
                </li>
              ))}
            </ul>
            <div class="mt-5 flex gap-5">
              {project.demoUrl && (
                <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class={iconLink}>
                  Demo
                </a>
              )}
              {project.repoUrl && (
                <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class={iconLink}>
                  Code
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
