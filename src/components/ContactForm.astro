---
// Ganti YOUR_FORM_ID dengan ID form dari https://formspree.io (Form settings → endpoint).
// Pakai form-ID, JANGAN email mentah, agar alamat email tidak terekspos di HTML.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';

const fieldClass =
  'mt-1 block w-full rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-slate-900 shadow-sm transition-colors placeholder:text-slate-400 focus:border-brand-600 focus:outline-none focus:ring-2 focus:ring-brand-600/30 dark:border-slate-700 dark:bg-slate-900 dark:text-white';
const labelClass = 'block text-sm font-medium text-slate-700 dark:text-slate-200';
---

<section id="contact" class="scroll-mt-20 bg-white py-24 dark:bg-slate-950">
  <div class="mx-auto max-w-2xl px-4 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
      Kontak
    </h2>
    <div class="mt-4 h-1 w-16 rounded-full bg-brand-600"></div>
    <p class="mt-4 text-slate-600 dark:text-slate-300">
      Jangan sungkan — kalau ingin tahu lebih lanjut tentang saya, kirim pesan di sini.
    </p>

    <form action={FORMSPREE_ENDPOINT} method="POST" class="mt-10 space-y-6" novalidate>
      <!-- Honeypot anti-spam: bot mengisi field ini, manusia tidak. -->
      <div class="hidden" aria-hidden="true">
        <label>Jangan diisi <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div>
        <label for="name" class={labelClass}>Nama</label>
        <input id="name" name="name" type="text" autocomplete="name" class={fieldClass} placeholder="Nama Anda" />
      </div>

      <div>
        <label for="email" class={labelClass}>Email <span class="text-red-500">*</span></label>
        <input id="email" name="email" type="email" required autocomplete="email" class={fieldClass} placeholder="email@contoh.com" />
        <p data-error-for="email" class="mt-1 hidden text-sm text-red-600 dark:text-red-400"></p>
      </div>

      <div>
        <label for="message" class={labelClass}>Pesan <span class="text-red-500">*</span></label>
        <textarea id="message" name="message" rows="5" required class={fieldClass} placeholder="Tulis pesan Anda..."></textarea>
        <p data-error-for="message" class="mt-1 hidden text-sm text-red-600 dark:text-red-400"></p>
      </div>

      <button
        type="submit"
        class="w-full rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-600/20 transition-colors hover:bg-brand-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600 sm:w-auto"
      >
        Kirim Pesan
      </button>

      <p data-form-status class="hidden text-sm" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact form');
  const status = form?.querySelector<HTMLParagraphElement>('[data-form-status]');

  const showError = (name: string, message: string) => {
    const el = form?.querySelector<HTMLParagraphElement>(`[data-error-for="${name}"]`);
    if (!el) return;
    el.textContent = message;
    el.classList.toggle('hidden', !message);
  };

  const validate = () => {
    let ok = true;
    const email = form?.elements.namedItem('email') as HTMLInputElement | null;
    const message = form?.elements.namedItem('message') as HTMLTextAreaElement | null;
    if (email && !email.validity.valid) {
      showError('email', 'Masukkan alamat email yang valid.');
      ok = false;
    } else {
      showError('email', '');
    }
    if (message && message.value.trim().length < 5) {
      showError('message', 'Pesan minimal 5 karakter.');
      ok = false;
    } else {
      showError('message', '');
    }
    return ok;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!status) return;
    if (!validate()) return;

    status.textContent = 'Mengirim…';
    status.className = 'text-sm text-slate-500 dark:text-slate-400';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (response.ok) {
        form.reset();
        status.textContent = 'Terima kasih! Pesan Anda sudah terkirim.';
        status.className = 'text-sm text-green-600 dark:text-green-400';
      } else {
        status.textContent = 'Maaf, terjadi kesalahan. Coba lagi nanti.';
        status.className = 'text-sm text-red-600 dark:text-red-400';
      }
    } catch {
      status.textContent = 'Gagal terhubung. Periksa koneksi Anda.';
      status.className = 'text-sm text-red-600 dark:text-red-400';
    }
  });
</script>
